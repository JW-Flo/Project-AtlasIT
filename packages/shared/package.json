{
  "name": "@atlasit/shared",
  "version": "0.1.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./*": {
      "types": "./dist/*.d.ts",
      "import": "./dist/*.js",
      "default": "./dist/*.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.1009.0",
    "@aws-sdk/client-lambda": "^3.1009.0",
    "@aws-sdk/client-s3": "^3.1009.0",
    "@aws-sdk/client-sqs": "^3.1009.0",
    "@aws-sdk/client-ssm": "^3.1009.0",
    "@aws-sdk/lib-dynamodb": "^3.1009.0",
    "hono": "^4.12.14",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@aws-sdk/client-eventbridge": "^3.1009.0",
    "@cloudflare/workers-types": "^4.20250927.0",
    "@types/aws-lambda": "^8.10.161",
    "@types/pg": "^8.20.0",
    "pg": "^8.13.3",
    "rimraf": "^6.0.1",
    "typescript": "^5.7.2",
    "vitest": "^3.2.4"
  }
}
