# Project Ignite Environment Variables
# Copy this file to .env and fill in the values

# Okta Configuration
OKTA_DOMAIN=your-domain.okta.com
OKTA_API_TOKEN_SA=your-okta-api-token

# Google Cloud Configuration
GCP_PROJECT_ID=ignite-459301
GCP_SA_KEY=your-gcp-service-account-key

# AWS Configuration
AWS_ACCESS_KEY_ID_SANDBOX=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY_SANDBOX=your-aws-secret-access-key
AWS_REGION=us-east-1

# Security Integrations
ROCKETCYBER_API_TOKEN=your-rocketcyber-api-token
DATTO_EDR_TOKEN=your-datto-edr-token
ZIP_API_KEY=your-zip-api-key
NETSUITE_TOKEN=your-netsuite-token

# Group IDs
GROUP_ID_SRE_CONTRACTORS=your-okta-group-id