# Enhanced Environment Example

# Okta Configuration
OKTA_DOMAIN=your-domain.okta.com
OKTA_API_TOKEN_SA=your-okta-api-token

# Google Cloud Configuration
GCP_PROJECT_ID=your-gcp-project-id
GCP_SA_KEY=your-gcp-service-account-key
GH_PAT=your-github-personal-access-token
GOOGLE_APPLICATION_CREDENTIALS=your-google-application-credentials
GOOGLE_DRIVE_FOLDER_URL=your-google-drive-folder-url
GOOGLE_SUPER_ADMIN_EMAIL=your-google-super-admin-email
GOOGLE_SUPER_ADMIN_PASSWORD=your-google-super-admin-password

# AWS Configuration
AWS_ACCESS_KEY_ID_SANDBOX=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY_SANDBOX=your-aws-secret-access-key
AWS_REGION=us-east-1

# Slack Configuration
SLACK_WEBHOOK_URL=your-slack-webhook-url

# OpenAI Configuration
OPENAI_API_KEY=your-openai-api-key
OPENAI_ORG_API_KEY=your-openai-org-api-key

# Added CLAUDE_API_TOKEN placeholder for API token
CLAUDE_API_TOKEN=your-claude-api-token

# Additional Configurations
DATTO_EDR_TOKEN=your-datto-edr-token
NETSUITE_TOKEN=your-netsuite-token
ROCKETCYBER_API_TOKEN=your-rocketcyber-api-token
ZIP_API_KEY=your-zip-api-key

# Group IDs
GROUP_ID_SRE_CONTRACTORS=your-okta-group-id

# Example environment variables for Project Ignite

# OpenAI API Key
OPENAI_API_KEY=your_openai_api_key_here

# Slack Webhook URL
SLACK_WEBHOOK_URL=your_slack_webhook_url_here

# GitHub Personal Access Token
GH_PAT=your_github_personal_access_token_here

# AI Model
AI_MODEL=gpt-4o

# GCP Project ID
GCP_PROJECT_ID=your_gcp_project_id_here

# Repository Name
GITHUB_REPO=JW-Flo/Project-Ignite