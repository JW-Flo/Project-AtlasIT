############################################################
# Project-AtlasIT Environment Template (.env.example)
# Copy to .env (local dev) and populate. NEVER commit real secrets.
# For 1Password CLI mapping: see ops/secrets/op-map.json (to be created)
############################################################

############################
# Core Platform (Cloudflare)
############################
CF_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=           # Preferred Cloudflare API token binding
CF_API_TOKEN=                   # Legacy fallback (kept for compatibility)
CF_API_EMAIL=
WRANGLER_PROJECT=atlasit-pages
CF_ACCOUNT_TAG=dev    # optional tag for multi-account scripts

###############
# Data Stores
###############
D1_DATABASE=ATLAS_ONBOARDING_DB        # D1 binding name
KV_NAMESPACE=atlasit_kv                # KV binding name
R2_BUCKET=atlasit-evidence             # R2 bucket for artifacts
DO_BINDING=AtlasDO                     # Durable Object class binding (optional)
DATABASE_URL=postgres://user:pass@host:5432/atlasit  # External backplane (optional)
S3_BUCKET=atlasit-evidence             # Mirror bucket (optional)
S3_REGION=us-east-1

#################
# Identity / IdP
#################
OKTA_DOMAIN=
OKTA_API_TOKEN=
OKTA_CLIENT_ID=
OKTA_CLIENT_SECRET=
FEATURE_IDP_OKTA=false

####################
# API / Service Keys
####################
ONBOARDING_API_KEY=
ORCHESTRATOR_API_KEY=
ORCHESTRATOR_URL=https://atlasit-orchestrator.kd8jc7v8cd.workers.dev   # Override orchestrator base (optional)
SCHEDULER_DEBUG_KEY=                                                     # MUST set a strong value
OPENAI_API_KEY=
TOGETHER_API_KEY=
GROQ_API_KEY=                   # Groq API key for AtlasIT Agent Mesh (qwen3-32b, llama-3.1-8b, etc.)
AI_FALLBACKS=groq,together      # Comma-separated fallback provider chain
SLACK_WEBHOOK_URL=

#############################
# Observability / Telemetry
#############################
LOG_LEVEL=info
SENTRY_DSN=
DATADOG_API_KEY=
SCHEMA_HASH_ENFORCE=true

#############################
# Rate Limiting (local dev)
#############################
RATE_LIMIT_MAX_REQUESTS=60
RATE_LIMIT_WINDOW_SECONDS=60

#############################
# CI/CD & Git Metadata
#############################
GIT_USER=AtlasIT Bot
GIT_EMAIL=bot@atlasit.local
GITHUB_TOKEN=
GH_PAT=

#############################
# Financial / External APIs
#############################
RAMP_API_KEY=
RAMP_CLIENT_ID=
RAMP_CLIENT_SECRET=

#############################
# Cloud (Optional Backplanes)
#############################
GCP_PROJECT_ID=
AWS_ACCESS_KEY_ID_SANDBOX=
AWS_SECRET_ACCESS_KEY_SANDBOX=
AWS_REGION=

#############################
# Misc / Experimental
#############################
CTX_PATH=./context/MasterSourceofTruth.txt
START_TIME=
END_TIME=

#############################
# Legacy / Deprecated
#############################
# MCP_URL (removed) was used by a deprecated external task dispatcher.
# If reintroduced, restore here and in agents.

# 1Password CLI Example (see ops/secrets):
# op run --env-file=.env -- node scripts/dev-start.mjs
