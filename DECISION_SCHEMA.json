{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://atlasit.dev/schemas/decision.json",
  "title": "Routing Decision Schema",
  "description": "Schema for agent routing decisions",
  "type": "object",
  "required": ["decision_id", "timestamp", "severity", "assignee", "rule_version", "rules_hash"],
  "properties": {
    "decision_id": {
      "type": "string",
      "format": "uuid",
      "description": "Unique identifier for this decision"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of decision"
    },
    "severity": {
      "type": "string",
      "enum": ["low", "medium", "high", "critical"],
      "description": "Severity level determined by routing logic"
    },
    "assignee": {
      "type": "string",
      "enum": ["copilot", "codex", "human"],
      "description": "Agent or human assigned to handle this PR"
    },
    "rule_version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "description": "Semantic version of routing rules applied"
    },
    "rules_hash": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$",
      "description": "SHA-256 hash of rules.json for verification"
    },
    "triggers": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "List of triggers that matched"
    },
    "rule_summary": {
      "type": "string",
      "description": "Optional human-readable summary of applied rules"
    },
    "pr_metadata": {
      "type": "object",
      "description": "PR metadata used in routing decision"
    }
  }
}
