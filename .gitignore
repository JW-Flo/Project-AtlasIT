# Node modules
node_modules/

# TypeScript build info (must not be committed — causes stale incremental builds)
*.tsbuildinfo

# Local creds and build artifacts
env/

# macOS metadata
.DS_Store

# Ignore environment files
.env
.env.backup
.env.*
**/.env
!.env.example

# Ignore virtual environments
.venv/
.mistral-venv/
venv/

# Ignore generated/temporary directories
backups/
Logs/
test-results/
qwen_eval_out/
issues/
context/

# Ignore keys and private certificates
Keys/
*.pem
*.key
*.crt

# Ignore Prometheus local env
Prometheus/.env

# VS Code: allow committed shared settings but still ignore local state files
.vscode/launch.json
.vscode/extensions.json

# Ignore Terraform state files
terraform.tfstate
terraform.tfstate.backup

# Lambda build artifacts
lambdas/*/dist/
*.zip

# Ignore Python cache files
__pycache__/
*.pyc

# Ignore logs
*.log

# Ignore other sensitive or generated files
# ai-agent/
*.bak
*.tmp

# Plaintext token/secret files — never commit
.dispatch_admin_token
*_admin_token
*_secret_key
credentials.json

# infra/
#   terraform/
#     aws/
#       main.tf
#       README.md
#     gcp/
#       main.tf
#       README.md
# context/aspnet-core-aspnetcore-9.0.pdf

# Ignore MCP/worker dev logs and background process artifacts
nohup.out
_remote.log
mcp/nohup.out
mcp/_remote.log

# Build outputs (JS, maps, type declarations)
dist/
**/dist/
onboarding/dist/
# packages/shared/dist/ is also ignored (built at install time)

# Prevent committing compiled JS in source (TypeScript packages)
packages/edge-utils/src/*.js
packages/edge-utils/src/*.js.map
packages/auth/src/*.js
packages/auth/src/*.js.map

# Example env file tracked separately; real env files ignored above
.env.example

# Ignore Terraform plugin cache and plans
**/.terraform/
*.tfplan
*.hcl
*.zip
# Ignore SvelteKit build artifacts
console-app/.svelte-kit/
console-app/build/

# Cloudflare Wrangler local state / telemetry
.wrangler/

# Claude worktrees for agent development
.claude/worktrees/

# Large local audit artifacts (regenerate on demand)
audit-full.json
audit-prod.json

# Third-party Cloudflare dashboard dump / legacy plugin code (exclude heavy static assets & vendor PHP deps)
docs/cloudflare/vendor/
docs/cloudflare/assets/
docs/cloudflare/fonts/
docs/cloudflare/*.php
docs/cloudflare/*.log
docs/cloudflare/*.map
docs/cloudflare/compiled.js
docs/cloudflare/compiled.js.map
docs/cloudflare/output.log
.env
packages/shared/dist/

# Vendored reference docs — ignore lockfiles to prevent Dependabot noise
docs/**/package-lock.json
docs/**/uv.lock
context/**/package-lock.json

# Project uses pnpm — prevent stale npm lockfiles from generating alerts
package-lock.json
**/package-lock.json
!pnpm-lock.yaml
