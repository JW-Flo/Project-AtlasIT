# Node modules
node_modules/

# Local creds and build artifacts
env/

# macOS metadata
.DS_Store

# Ignore environment files
.env
.env.backup
.env.*
**/.env
!.env.example

# Ignore virtual environments
.venv/
venv/

# Ignore keys and private certificates
Keys/
*.pem
*.key
*.crt

# Ignore Prometheus local env
Prometheus/.env

# VS Code: allow committed shared settings but still ignore local state files
.vscode/launch.json
.vscode/extensions.json

# Ignore Terraform state files
terraform.tfstate
terraform.tfstate.backup

# Ignore Python cache files
__pycache__/
*.pyc

# Ignore logs
*.log

# Ignore other sensitive or generated files
# ai-agent/
*.bak
*.tmp

# infra/
#   terraform/
#     aws/
#       main.tf
#       README.md
#     gcp/
#       main.tf
#       README.md
# context/aspnet-core-aspnetcore-9.0.pdf

# Ignore MCP/worker dev logs and background process artifacts
nohup.out
_remote.log
mcp/nohup.out
mcp/_remote.log

# Build outputs (JS, maps, type declarations)
dist/
**/dist/
onboarding/dist/
# Exception: commit shared dist (used by workers without build step in certain deployments)
!packages/shared/dist/

# Prevent committing compiled JS in source (TypeScript packages)
packages/edge-utils/src/*.js
packages/edge-utils/src/*.js.map
packages/auth/src/*.js
packages/auth/src/*.js.map

# Example env file tracked separately; real env files ignored above
.env.example

# Ignore Terraform plugin cache and plans
**/.terraform/
*.tfplan
*.hcl
*.zip
# Ignore SvelteKit build artifacts
console-app/.svelte-kit/

# Cloudflare Wrangler local state / telemetry
.wrangler/

# Evidence artifacts (generated during CI, keep structure)
.evidence/*.json
!.evidence/.keep

# Large local audit artifacts (regenerate on demand)
audit-full.json
audit-prod.json

# Third-party Cloudflare dashboard dump / legacy plugin code (exclude heavy static assets & vendor PHP deps)
docs/cloudflare/vendor/
docs/cloudflare/assets/
docs/cloudflare/fonts/
docs/cloudflare/*.php
docs/cloudflare/*.log
docs/cloudflare/*.map
docs/cloudflare/compiled.js
docs/cloudflare/compiled.js.map
docs/cloudflare/output.log
.env
