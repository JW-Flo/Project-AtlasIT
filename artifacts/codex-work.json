{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "description": "Protected Codex-owned feature boundaries to avoid Copilot overlap.",
  "protected": {
    "migrations": [
      "compliance-worker/migrations",
      "ai-orchestrator/migrations"
    ],
    "policy": ["**/policy/**", "**/policies/**"],
    "rbac": ["**/rbac/**", "**/auth/**"],
    "automation": ["compliance-worker/src/modules/automation/**"],
    "upcoming": [
      "compliance-worker/src/modules/policy/**",
      "ai-orchestrator/src/policy/**"
    ],
    "openapi": ["**/openapi*.json", "**/openapi*.yaml"],
    "scan-stub": ["**/security-scan/**", "**/scan/**"]
  },
  "notes": [
    "Append new protected areas instead of modifying existing arrays",
    "Copilot guard script enforces no direct edits unless allowlisted"
  ]
}
