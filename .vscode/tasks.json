{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "codex:run PR in container",
      "type": "shell",
      "command": "docker",
      "args": [
        "run",
        "--rm",
        "-v",
        "${workspaceFolder}:/workspace",
        "-w",
        "/workspace",
        "codex:latest",
        "bash",
        "tools/codex-exec.sh",
        "/workspace",
        "${input:prId}",
        "${input:agentId}"
      ],
      "problemMatcher": []
    },
    {
      "label": "codex:build image",
      "type": "shell",
      "command": "docker",
      "args": [
        "build",
        "-f",
        "tools/Dockerfile.codex",
        "-t",
        "codex:latest",
        "."
      ],
      "problemMatcher": []
    },
    {
      "label": "sonar:start",
      "type": "shell",
      "command": "docker",
      "args": [
        "run",
        "--rm",
        "-d",
        "--name",
        "sonarqube-local",
        "-p",
        "9000:9000",
        "sonarqube:lts"
      ],
      "problemMatcher": [],
      "detail": "Start local SonarQube (Eclipse Temurin JRE bundled in image)"
    },
    {
      "label": "sonar:scan",
      "type": "shell",
      "command": "npm",
      "args": ["run", "sonar:scan"],
      "problemMatcher": [],
      "dependsOn": ["sonar:start"],
      "detail": "Run local sonar scan after starting server"
    }
  ],
  "inputs": [
    {
      "id": "prId",
      "type": "promptString",
      "description": "PR id (e.g. PR4)",
      "default": "PR4"
    },
    {
      "id": "agentId",
      "type": "promptString",
      "description": "Agent id",
      "default": "a1"
    }
  ]
}
