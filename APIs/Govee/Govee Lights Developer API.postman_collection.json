{
	"info": {
		"_postman_id": "3733b3c4-7f81-43e2-86c4-b73197113057",
		"name": "Govee Lights Developer API",
		"description": "The Govee Developer API collection allows developers to integrate Govee smart light devices into their applications or services.\n\nWith this API, developers can control Govee smart lights and access various functions, including turning lights on and off, changing the color and brightness, and setting schedules and timers.\n\nAdditionally, the Govee Developer API provides access to real-time device information, such as device status, enabling developers to create more advanced applications and services.\n\nReference: [https://govee-api.readthedocs.io/en/latest/index.html](https://govee-api.readthedocs.io/en/latest/index.html)",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
		"_exporter_id": "19412839",
		"_collection_link": "https://www.postman.com/postman/workspace/program-smart-lights/collection/16712233-3733b3c4-7f81-43e2-86c4-b73197113057?action=share&source=collection_link&creator=19412839"
	},
