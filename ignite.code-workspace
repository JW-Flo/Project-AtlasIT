{
  "folders": [
    { "path": "." }
  ],
  "settings": {
    "github.copilot.cli.path": "${workspaceFolder}/.tools/copilot-cli/bin/copilot"
  },
  "tasks": {
    "version": "2.0.0",
    "tasks": [
      {
        "label": "Flat Copilot Run",
        "type": "shell",
        "command": "PAYLOAD=$(node mcp/flat-bundle.js) && echo \"$PAYLOAD\" | copilot chat --model gpt-4o --stdin --json-input --output-file ci/plan.md",
        "group": "build",
        "problemMatcher": []
      }
    ]
  }
}
