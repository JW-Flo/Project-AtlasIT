{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "node",
    "lib": ["ES2022", "DOM"],
    "allowJs": true,
    "outDir": "./dist",
    "rootDir": "./",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "types": ["vitest", "@cloudflare/workers-types"],
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@onboarding/*": ["./onboarding/src/*"],
      "@marketplace/*": ["./marketplace/src/*"],
      "@auth/*": ["./auth/src/*"],
      "@orchestrator/*": ["./orchestrator/src/*"],
      "@api-manager/*": ["./api-manager/src/*"],
      "@applications/*": ["./applications/src/*"],
      "@atlasit/shared": ["./packages/shared/src"],
      "@atlasit/idp": ["./packages/idp/src"],
      "@atlasit/idp-adapters/okta": ["./packages/idp-adapters/okta/src"]
    }
  },
  "include": ["**/*.ts", "**/*.tsx"],
  "exclude": ["node_modules", "dist", "**/*.test.ts", "**/*.spec.ts"]
}
