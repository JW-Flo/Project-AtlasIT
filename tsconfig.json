{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "node",
    "lib": ["ES2022", "DOM"],
    "allowJs": true,
    "outDir": "./dist",
    "rootDir": "./",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "types": ["vitest", "@cloudflare/workers-types"],
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@onboarding/*": ["./onboarding/src/*"],
      "@marketplace/*": ["./marketplace/src/*"],
      "@auth/*": ["./auth/src/*"],
      "@orchestrator/*": ["./orchestrator/src/*"],
      "@api-manager/*": ["./api-manager/src/*"],
      "@applications/*": ["./applications/src/*"],
      "@atlasit/shared": ["./packages/shared/src"],
      "@atlasit/idp": ["./packages/idp/src"],
      "@atlasit/idp-okta": ["./packages/idp-adapters/okta/src"],
      "@atlasit/edge-utils": ["./packages/edge-utils/src"],
      "@atlasit/shared-types": ["./packages/shared-types/src"],
      "@atlasit/connector-schema": ["./packages/connector-schema/src"]
    }
  },
  "include": [
    "playwright.config.ts",
    "onboarding/src/**/*.ts",
    "onboarding/src/**/*.tsx",
    "ai-orchestrator/**/*.ts",
    "packages/*/src/**/*.ts",
    "packages/*/src/**/*.tsx",
    "documentation-worker/src/**/*.ts",
    "documentation-worker/test/**/*.ts",
    "scripts/**/*.ts",
    "compliance-worker/src/**/*.ts",
    "src/**/*.ts",
    "dispatch-worker/src/**/*.ts",
    "shared/services/**/*.ts",
    "shared/integrations/**/*.ts",
    "shared/connectors/**/*.ts",
    "lambdas/*/src/**/*.ts",
    "core-api/src/**/*.ts",
    "marketplace/src/**/*.ts",
    "agents/*/src/**/*.ts",
    "adapters/*/src/**/*.ts",
    "test/**/*.ts",
    "vitest.workspace.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "coverage",
    "apps",
    "auth",
    "context",
    "docs/servers-main",
    "documentation-worker/dist",
    "packages/**/dist",
    "**/*.spec.ts",
    "**/*.spec.tsx",
    "ai-orchestrator/**/*.test.ts"
  ]
}
