{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "node",
    "lib": ["ES2022", "DOM"],
    "allowJs": true,
    "outDir": "./dist",
    "rootDir": "./",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "types": [],
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@onboarding/*": ["./onboarding/src/*"],
      "@marketplace/*": ["./marketplace/src/*"],
      "@auth/*": ["./auth/src/*"],
      "@orchestrator/*": ["./orchestrator/src/*"],
      "@api-manager/*": ["./api-manager/src/*"],
      "@applications/*": ["./applications/src/*"]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "**/*.test.ts",
    "**/*.spec.ts"
  ]
}
