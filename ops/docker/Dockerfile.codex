# syntax=docker/dockerfile:1.7
FROM node:20-alpine

# Install required tooling for Codex container
RUN apk add --no-cache bash git tini

# Enable corepack so pnpm can be used if needed
ENV COREPACK_ENABLE_DOWNLOAD_PROMPT=0
RUN corepack enable || true

WORKDIR /workspace

# Copy package manifests first to maximize build caching
COPY package.json package-lock.json pnpm-workspace.yaml ./
COPY onboarding/package.json onboarding/
COPY onboarding/package-lock.json onboarding/
COPY ai-orchestrator/package.json ai-orchestrator/
COPY documentation-worker/package.json documentation-worker/
COPY documentation-worker/package-lock.json documentation-worker/
COPY console-app/package.json console-app/
COPY compliance-worker/package.json compliance-worker/
COPY mcp-idp/package.json mcp-idp/
COPY customer-worker-1/package.json customer-worker-1/
COPY demo-app/package.json demo-app/
COPY packages/adapter-gen/package.json packages/adapter-gen/
COPY packages/adapter-sim/package.json packages/adapter-sim/
COPY packages/auth/package.json packages/auth/
COPY packages/edge-utils/package.json packages/edge-utils/
COPY packages/idp/package.json packages/idp/
COPY packages/idp-sim/package.json packages/idp-sim/
COPY packages/jw-site/package.json packages/jw-site/
COPY packages/research-engine/package.json packages/research-engine/
COPY packages/shared/package.json packages/shared/

# Install dependencies with npm workspaces support
RUN npm ci --workspaces --include-workspace-root

# Copy the rest of the repository
COPY . .

ENTRYPOINT ["/sbin/tini", "--"]
CMD ["bash", "docker/codex-exec.sh", "/workspace"]
