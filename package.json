{
  "name": "atlasit",
  "version": "1.0.0",
  "description": "AtlasIT - Cloud-first IT management platform for SMBs",
  "main": "index.js",
  "scripts": {
    "dev": "npm-run-all --parallel dev:*",
    "dev:onboarding": "cd onboarding && npm run dev",
    "dev:marketplace": "cd marketplace && npm run dev",
    "dev:auth": "cd auth && npm run dev",
    "dev:orchestrator": "cd orchestrator && npm run dev",
    "dev:api-manager": "cd api-manager && npm run dev",
    "dev:applications": "cd applications && npm run dev",
    "build": "npm-run-all --parallel build:*",
    "build:onboarding": "cd onboarding && npm run build",
    "build:marketplace": "cd marketplace && npm run build",
    "build:auth": "cd auth && npm run build",
    "build:orchestrator": "cd orchestrator && npm run build",
    "build:api-manager": "cd api-manager && npm run build",
    "build:applications": "cd applications && npm run build",
    "test": "npm-run-all --parallel test:*",
    "test:onboarding": "cd onboarding && npm test",
    "test:marketplace": "cd marketplace && npm test",
    "test:auth": "cd auth && npm test",
    "test:orchestrator": "cd orchestrator && npm test",
    "test:api-manager": "cd api-manager && npm test",
    "test:applications": "cd applications && npm test",
    "lint": "eslint . --ext .ts,.tsx",
    "format": "prettier --write \"**/*.{ts,tsx,json,md}\""
  },
  "keywords": [
    "it-management",
    "saas",
    "cloud",
    "automation",
    "serverless"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.0.0",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.0.0",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "@cloudflare/workers-types": "^4.0.0",
    "dotenv": "^16.0.0",
    "express": "^4.18.0",
    "winston": "^3.0.0",
    "zod": "^3.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
