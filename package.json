{
  "name": "atlasit",
  "version": "1.0.0",
  "description": "AtlasIT - Cloud-first IT management platform for SMBs",
  "type": "module",
  "main": "index.js",
  "workspaces": [
    "packages/*",
    "onboarding",
    "ai-orchestrator",
    "mcp*",
    "documentation-worker",
    "slack-approval-worker"
  ],
  "scripts": {
    "dev": "npm-run-all --parallel dev:*",
    "scan:secrets": "node scripts/scan-secrets.js",
    "dev:onboarding": "cd onboarding && npm run dev",
    "dev:marketplace": "cd marketplace && npm run dev",
    "dev:auth": "cd auth && npm run dev",
    "dev:orchestrator": "cd ai-orchestrator && npm run dev",
    "dev:api-manager": "cd api-manager && npm run dev",
    "dev:applications": "cd applications && npm run dev",
    "dev:core": "npm-run-all --parallel dev:onboarding dev:orchestrator",
    "install:all": "npm install --workspaces --include-workspace-root",
    "build": "npm-run-all --parallel build:*",
    "build:onboarding": "cd onboarding && npm run build",
    "build:marketplace": "cd marketplace && npm run build",
    "build:auth": "cd auth && npm run build",
    "build:orchestrator": "cd ai-orchestrator && npm run build",
    "build:api-manager": "cd api-manager && npm run build",
    "build:applications": "cd applications && npm run build",
    "build:shared": "cd packages/shared && npm run build",
    "test": "npm-run-all --parallel test:*",
    "test:onboarding": "cd onboarding && npm test",
    "test:marketplace": "cd marketplace && npm test",
    "test:auth": "cd auth && npm test",
    "test:orchestrator": "cd ai-orchestrator && npm test",
    "test:api-manager": "cd api-manager && npm test",
    "test:applications": "cd applications && npm test",
    "test:core": "npm-run-all --parallel test:onboarding test:orchestrator",
    "lint": "eslint .",
    "format": "prettier --write \"**/*.{ts,tsx,json,md}\"",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "pretest:unit": "npm run build:shared",
    "pretest:coverage": "npm run build:shared",
    "test:unit": "vitest run",
    "test:coverage": "vitest run --coverage",
    "migrate:onboarding": "cd onboarding && wrangler d1 migrations apply ATLAS_ONBOARDING_DB",
    "schema:hash": "node scripts/schema-hash.js",
    "prepare": "husky install"
  },
  "keywords": [
    "it-management",
    "saas",
    "cloud",
    "automation",
    "serverless"
  ],
  "author": "",
  "license": "MIT",
  "lint-staged": {
    "*.{js,ts,tsx}": [
      "eslint --max-warnings=0 --no-warn-ignored",
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@typescript-eslint/eslint-plugin": "^8.18.2",
    "@typescript-eslint/parser": "^8.18.2",
    "eslint": "^9.17.0",
    "vitest": "^2.1.9",
    "vite": "^5.4.8",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.0.0",
    "typescript": "^5.7.2",
    "husky": "^9.0.0",
    "lint-staged": "^15.0.0"
  },
  "dependencies": {
    "@cloudflare/workers-types": "^4.0.0",
    "dotenv": "^16.0.0",
    "express": "^4.18.0",
    "winston": "^3.0.0",
    "zod": "^3.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
